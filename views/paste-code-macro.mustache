<!DOCTYPE html>
<html lang="en">
   <head>
      <!-- Require and AMD dependencies -->
      <script src="//cdnjs.cloudflare.com/ajax/libs/require.js/2.1.22/require.min.js"></script>
      <link rel="stylesheet" href="//aui-cdn.atlassian.com/aui-adg/5.9.4/css/aui.css" media="all">
      <script src="//ajax.googleapis.com/ajax/libs/jquery/1.8.3/jquery.min.js"></script>
      <script src="//aui-cdn.atlassian.com/aui-adg/5.9.4/js/aui.js"></script>
      <script src="//aui-cdn.atlassian.com/aui-adg/5.9.4/js/aui-datepicker.js"></script>
      <link rel="stylesheet" href="//aui-cdn.atlassian.com/aui-adg/5.9.4/css/aui-experimental.css" media="all">
      <script src="//aui-cdn.atlassian.com/aui-adg/5.9.4/js/aui-experimental.js"></script>
      <script src="//aui-cdn.atlassian.com/aui-adg/5.9.4/js/aui-soy.js"></script>

      <link type="text/css" rel="stylesheet" title="Default" href="//cdnjs.cloudflare.com/ajax/libs/highlight.js/9.2.0/styles/default.min.css">
      {{#avaliableStyles}}
      <link type="text/css" rel="alternate stylesheet" title="{{theme}}" href="//cdnjs.cloudflare.com/ajax/libs/highlight.js/9.2.0/styles/{{theme}}.min.css">
      {{/avaliableStyles}}

      <link rel="stylesheet" type="text/css" href="/static/css/all.css">
      <script src="/static/js/app/paste-code-macro.js" type="text/javascript"></script>
      <script type="text/javascript">require(['app/paste-code-macro']);</script>

      {{=<% %>=}}
      <script id="paste" type="x-tmpl-mustache">
      <div class="paste">
         {{#title}}
         <div class="heading"><span class="title">{{title}}</span></div>
         {{/title}}
         <div class="contents">
            <button id="copy-to-clipboard" class="aui-button aui-button-subtle" data-clipboard-target="#code-preview" title="Copied!"><span class="aui-icon aui-icon-small aui-iconfont-copy-clipboard ">Copy </span> Copy to clipboard</button>
            <pre><code id="code-preview {{language}}">{{contents}}</code></pre>
         </div>
      </div>
      </script>
      <%={{ }}=%>
   </head>
   <body class="paste-code-macro">
      <section id="content" class="ac-content">
      </section>
   </body>
</html>
