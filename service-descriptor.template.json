{{#.}}
{
   "name": "Better Code Macro for Confluence",
   "description": "Atlassian Connect addon to provide a better code macro for Confluence Cloud",
   "computeClassification": {
      "dataType": [
         "Atlassian/Static"
      ]
   },
   "network": {
      "egress":  "internet-only"
   },
   "resources": [{
      "type": "globaledge",
      "name": "ingress",
      "attributes": {
         "ip_whitelist": [
           "public"
         ]
      }
   }],
   "environmentOverrides": {
      "dev": {
         "config": {
            "environmentVariables": {
               "HOST_URL": "https://cloud-code-macro.dev.services.atlassian.com"
            }
         }
      },
      "prod": {
         "config": {
            "environmentVariables": {
               "HOST_URL": "https://cloud-code-macro.services.atlassian.com"
            }
         }
      }
   },
   "organization": "Ecosystem Engineering",
   "owners": [ "rmassaioli@atlassian.com" ],
   "scaling": {
      "min": 1
   },
   "notifications": {
      "email": "rmassioli@atlassian.com",
      "pagerduty": {
         "cloudwatch": "https://events.pagerduty.com/integration/81b318b251424cf2bbbd41f9db531d8d/enqueue",
         "apiKey": "81b318b251424cf2bbbd41f9db531d8d"
      }
   },
   "links": {
      "binary": {
         "name": "docker.atl-paas.net/sox/atlassian/cloud-code-macro",
         "type": "docker",
         "tag": "{{RELEASE_VERSION}}"
      },
      "healthcheck": {
         "uri": "rest/heartbeat"
      },
      "source": {
         "url": "https://bitbucket.org/robertmassaioli/cloud-code-macro"
      }
   },
   "alarms": {
      "overrides": {
         "WebServerDiskSpaceUtilizationAlarmHigh": {
            "Priority": "Low"
         },
         "HighSeverityAlarmWhenTooManyBackend5xxErrors": {
            "Priority": "Low"
         },
         "HighSeverityAlarmWhenTooManyELB5xxErrors": {
            "Priority": "Low"
         },
         "HealthyHostCount": {
            "Priority": "Low"
         }
      }
   }
}
{{/.}}
